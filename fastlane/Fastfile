default_platform(:android)

platform :android do

  desc "Build a signed release AAB. Pass version_code: N to override."
  lane :build do |options|
    props = {
      "android.injected.signing.store.file"     => ENV["KEYSTORE_PATH"],
      "android.injected.signing.store.password" => ENV["KEYSTORE_STORE_PASSWORD"],
      "android.injected.signing.key.alias"      => ENV["KEYSTORE_KEY_ALIAS"],
      "android.injected.signing.key.password"   => ENV["KEYSTORE_KEY_PASSWORD"],
    }
    props["version_code"] = options[:version_code].to_s if options[:version_code]
    gradle(
      task:        "bundle",
      build_type:  "Release",
      project_dir: "android/",
      properties:  props,
    )
  end

  desc "Build + upload to Play Store Internal Testing track"
  lane :deploy_internal do |options|
    build(version_code: options[:version_code])
    upload_to_play_store(
      track:                 "internal",
      aab:                   "android/app/build/outputs/bundle/release/app-release.aab",
      skip_upload_apk:       true,
      skip_upload_metadata:  true,
      skip_upload_images:    true,
      skip_upload_screenshots: true,
    )
  end

  desc "Promote Internal → Closed Testing (alpha)"
  lane :promote_alpha do
    upload_to_play_store(
      track:            "internal",
      track_promote_to: "alpha",
      skip_upload_apk:  true,
      skip_upload_aab:  true,
    )
  end

  desc "Promote Closed Testing → Open Testing (beta)"
  lane :promote_beta do
    upload_to_play_store(
      track:            "alpha",
      track_promote_to: "beta",
      skip_upload_apk:  true,
      skip_upload_aab:  true,
    )
  end

  desc "Promote Open Testing → Production (full rollout)"
  lane :promote_production do
    upload_to_play_store(
      track:            "beta",
      track_promote_to: "production",
      rollout:          "1.0",
      skip_upload_apk:  true,
      skip_upload_aab:  true,
    )
  end

end
